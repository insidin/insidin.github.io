---
import { getCollection } from 'astro:content';

const allTakes = await getCollection('takes');
const allArticles = await getCollection('articles');

const recentTakes = allTakes
  .filter(t => !t.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const linkedInProfile = 'https://be.linkedin.com/in/januyttenhove';

function resolveArticle(linkedArticle: string | undefined) {
  if (!linkedArticle) return null;
  const article = allArticles.find(a => a.id === linkedArticle);
  if (!article) return null;
  const slug = article.id.split('/').pop();
  return {
    title: article.data.title,
    href: `/topics/${article.data.topic}/${slug}`,
  };
}
---

<section class="bg-white py-20 border-t border-border">
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="flex items-end justify-between mb-10">
      <div>
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="w-7 h-px bg-accent"></span>
          <span class="mono-xs text-accent">Takes</span>
        </div>
        <h2 class="d-l text-primary">Latest thinking</h2>
      </div>
      <a href="/takes" class="d-s text-primary hover:text-accent transition-colors hidden md:block">
        All takes &rarr;
      </a>
    </div>

    <div class="space-y-0">
      {recentTakes.map(take => {
        const linked = resolveArticle(take.data.linkedArticle);
        const socialLink = take.data.socialLinks?.find(s => s.platform === 'linkedin' && s.url);
        const discussionUrl = socialLink?.url || linkedInProfile;

        return (
          <div class="flex gap-5 py-5 border-b border-border">
            <div class="w-14 shrink-0 pt-0.5">
              <span class="mono-xs text-muted">
                {new Date(take.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="d-m text-primary mb-1.5" style="line-height:1.4;font-size:0.975rem">{take.data.hook}</p>
              <div class="flex items-center gap-3 flex-wrap">
                {take.data.tags.slice(0, 2).map(tag => (
                  <span class="mono-xs px-2 py-0.5 bg-surface text-muted" style="border-radius:9999px;font-size:0.575rem">{tag}</span>
                ))}
                {linked && (
                  <a href={linked.href} class="mono-xs text-accent hover:text-primary transition-colors" style="font-size:0.6rem">
                    Read more &rarr;
                  </a>
                )}
                <a
                  href={discussionUrl}
                  target="_blank"
                  rel="noopener"
                  class="ml-auto inline-flex items-center gap-1 mono-xs text-muted hover:text-accent transition-colors"
                  style="font-size:0.575rem"
                >
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  Discuss
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <a href="/takes" class="d-s text-primary hover:text-accent transition-colors mt-6 inline-block md:hidden">
      All takes &rarr;
    </a>
  </div>
</section>
