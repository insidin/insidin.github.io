---
import { getEntry, render } from 'astro:content';

const contactEntry = await getEntry('sitePages', 'contact');
const { Content } = await render(contactEntry);
const { eyebrow, headline, ctaPrimary, ctaSecondary } = contactEntry.data;
---

<section id="contact" class="bg-primary py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      {eyebrow && (
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="w-8 h-px bg-accent"></span>
          <span class="mono-xs text-accent">{eyebrow}</span>
        </div>
      )}
      <h2 class="d-l text-white mb-6">
        {headline}
      </h2>
      <div class="b-l text-white/80 mb-10">
        <Content />
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        {ctaPrimary && (
          <a
            href={ctaPrimary.href}
            class="inline-flex items-center gap-3 px-6 py-4 bg-accent text-primary font-semibold text-sm hover:opacity-90 transition-opacity"
            style="border-radius: var(--radius-sm);"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {ctaPrimary.label}
          </a>
        )}
        {ctaSecondary && (
          <a
            href={ctaSecondary.href}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-3 px-6 py-4 border border-white/30 text-white font-semibold text-sm hover:border-accent hover:text-accent transition-colors"
            style="border-radius: var(--radius-sm);"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            {ctaSecondary.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
