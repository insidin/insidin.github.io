---
import { getEntry, render } from 'astro:content';

const aboutEntry = await getEntry('sitePages', 'about');
const { Content } = await render(aboutEntry);
const { name, social, howIWork } = aboutEntry.data;
---

<section id="about" class="bg-white py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="w-8 h-px bg-accent"></span>
          <span class="mono-xs text-accent">About</span>
        </div>
        <h2 class="d-l text-primary mb-6">
          {name || 'Jan Uyttenhove'}
        </h2>
        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Social links -->
        {social && social.length > 0 && (
          <div class="flex gap-4 mt-8 flex-wrap">
            {social.map(link => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="d-s text-primary hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- How I work card -->
      {howIWork && howIWork.length > 0 && (
        <div class="relative">
          <div class="bg-primary text-white p-8" style="border-radius: var(--radius-sm);">
            <div class="mono-xs text-accent mb-6">How I work</div>
            <div class="space-y-5">
              {howIWork.map(item => (
                <div class="flex gap-4 items-start">
                  <div class="mt-1 w-2 h-2 bg-accent shrink-0" style="border-radius: 50%;"></div>
                  <div>
                    <div class="d-s text-white mb-1">{item.label}</div>
                    <div class="b-s text-white/70 leading-relaxed">{item.detail}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

    </div>
  </div>
</section>
