---
const year = new Date().getFullYear();
---

<footer class="bg-primary border-t border-white/[0.08] py-9">
  <div class="max-w-[1100px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-5">
      <span class="font-display font-bold text-white text-base" style="letter-spacing:-0.02em">Insidin</span>
      <span class="text-white/20 hidden md:block">|</span>
      <nav class="flex gap-5">
        <a href="https://dg2dmm.com" target="_blank" rel="noopener" class="b-s text-white/40 hover:text-accent transition-colors">DG2DMM</a>
        <a href="/topics" class="b-s text-white/40 hover:text-accent transition-colors">Insights</a>
      </nav>
    </div>
    <div class="flex items-center gap-4">
      <span class="mono-xs text-white/25">Belgium, EU</span>
      <span class="text-white/15 hidden md:block">|</span>
      <span class="text-white/25 text-xs">&copy; {year} Insidin</span>
    </div>
  </div>
</footer>
