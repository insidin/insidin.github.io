---
import { getEntry, getCollection, render } from 'astro:content';

const heroEntry = await getEntry('sitePages', 'hero');
const { Content } = await render(heroEntry);
const { eyebrow, headline, headlineAccent, ctaPrimary, ctaSecondary } = heroEntry.data;

// Build stats: 2 fixed + 2 most recently active topics
const allArticles = await getCollection('articles');
const allTopics = await getCollection('topics');

// Find topics with the most recent article activity
const topicActivity = allTopics
  .map(topic => {
    const articles = allArticles.filter(a => a.data.topic === topic.id && !a.data.draft);
    const latestDate = articles.length > 0
      ? Math.max(...articles.map(a => new Date(a.data.date).getTime()))
      : 0;
    return { topic, articleCount: articles.length, latestDate };
  })
  .filter(t => t.articleCount > 0)
  .sort((a, b) => b.latestDate - a.latestDate);

const recentTopics = topicActivity.slice(0, 2);

const stats = [
  { value: '25+', label: 'Years of applied practice' },
  { value: 'DG2DMM', label: 'Outcome-driven framework' },
  ...recentTopics.map(t => ({
    value: t.topic.data.title,
    label: `${t.articleCount} article${t.articleCount !== 1 ? 's' : ''} published`,
    href: `/topics/${t.topic.id}`,
  })),
];
---

<section class="relative bg-primary min-h-[90vh] flex items-center overflow-hidden pt-16">
  <!-- Background grid texture -->
  <div class="absolute inset-0 opacity-[0.04]">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>
  <div class="absolute top-[20%] right-[-5%] w-[400px] h-[400px] bg-accent opacity-[0.06] rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-[1100px] mx-auto px-6 py-24">
    <div class="max-w-[680px]">
      <!-- Eyebrow -->
      {eyebrow && (
        <div class="inline-flex items-center gap-2 mb-6">
          <span class="w-7 h-px bg-accent"></span>
          <span class="mono-xs text-accent">{eyebrow}</span>
        </div>
      )}

      <!-- Headline -->
      <h1 class="d-xl text-white mb-5">
        {headline}<br />
        <span class="text-accent">{headlineAccent}</span>
      </h1>

      <!-- Subtitle from body -->
      <div class="b-l text-white/70 mb-10 max-w-[600px]">
        <Content />
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3.5">
        {ctaPrimary && (
          <a
            href={ctaPrimary.href}
            class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-primary d-s hover:opacity-90 transition-opacity"
            style="border-radius: var(--radius-sm);"
          >
            {ctaPrimary.label}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
        {ctaSecondary && (
          <a
            href={ctaSecondary.href}
            class="inline-flex items-center gap-2 px-6 py-3 border border-white/30 text-white/80 d-s hover:border-accent hover:text-accent transition-colors"
            style="border-radius: var(--radius-sm);"
          >
            {ctaSecondary.label}
          </a>
        )}
      </div>
    </div>

    <!-- Stats row -->
    <div class="mt-[72px] pt-9 border-t border-white/[0.15] grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map(stat => (
        stat.href ? (
          <a href={stat.href} class="group block">
            <div class="d-s text-white group-hover:text-accent transition-colors mb-0.5">{stat.value}</div>
            <div class="b-s text-white/50">{stat.label}</div>
          </a>
        ) : (
          <div>
            <div class="d-s text-white mb-0.5">{stat.value}</div>
            <div class="b-s text-white/50">{stat.label}</div>
          </div>
        )
      ))}
    </div>
  </div>
</section>
