---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const topics = await getCollection('topics');
  return topics.map(topic => ({
    params: { topic: topic.id },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const { Content } = await render(topic);

const allArticles = await getCollection('articles');
const topicArticles = allArticles
  .filter(a => a.data.topic === topic.id && !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const documents = topic.data.documents || [];
---

<Layout
  title={`${topic.data.title} - Insidin`}
  description={topic.data.description}
>
  <article class="pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 mono-xs text-muted">
          <li><a href="/" class="hover:text-accent transition-colors">Insidin</a></li>
          <li>/</li>
          <li><a href="/topics" class="hover:text-accent transition-colors">Topics</a></li>
          <li>/</li>
          <li class="text-primary">{topic.data.title}</li>
        </ol>
      </nav>

      <!-- Topic header -->
      <header class="mb-16">
        <div class="flex flex-wrap gap-2 mb-6">
          {topic.data.tags.map(tag => (
            <span class="mono-xs px-2.5 py-1 bg-surface text-muted" style="border-radius:9999px">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="d-xl text-primary mb-6">{topic.data.title}</h1>
        <div class="prose max-w-none">
          <Content />
        </div>
      </header>

      <!-- Articles -->
      {topicArticles.length > 0 && (
        <section class="mb-16">
          <div class="inline-flex items-center gap-2 mb-8">
            <span class="w-8 h-px bg-accent"></span>
            <span class="mono-xs text-accent">Articles</span>
          </div>
          <div class="space-y-6">
            {topicArticles.map(article => {
              const slug = article.id.split('/').pop();
              return (
                <a
                  href={`/topics/${topic.id}/${slug}`}
                  class="group block bg-white p-6 border-[1.5px] border-primary hover:border-accent transition-colors"
                  style="border-radius: var(--radius-sm);"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="d-m text-primary group-hover:text-accent transition-colors mb-2">
                        {article.data.title}
                      </h3>
                      <div class="flex items-center gap-4">
                        <span class="mono-xs text-muted">
                          {new Date(article.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                        </span>
                        <span class="mono-xs text-muted">{article.data.readTime}</span>
                      </div>
                    </div>
                    <svg class="w-5 h-5 text-muted group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- Documents -->
      {documents.length > 0 && (
        <section class="mb-16">
          <div class="inline-flex items-center gap-2 mb-8">
            <span class="w-8 h-px bg-accent"></span>
            <span class="mono-xs text-accent">Documents</span>
          </div>
          <div class="space-y-4">
            {documents.map(doc => (
              <a
                href={`/documents/${doc.file}`}
                target="_blank"
                rel="noopener"
                class="group flex items-center gap-4 bg-white p-5 border-[1.5px] border-primary hover:border-accent transition-colors"
                style="border-radius: var(--radius-sm);"
              >
                <div class="w-10 h-10 bg-surface flex items-center justify-center shrink-0" style="border-radius: var(--radius-sm);">
                  <svg class="w-5 h-5 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="d-s text-primary group-hover:text-accent transition-colors">{doc.title}</div>
                  {doc.description && <div class="b-s text-muted mt-0.5">{doc.description}</div>}
                </div>
                <div class="mono-xs text-muted shrink-0">PDF</div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Back link -->
      <div class="pt-8 border-t border-border">
        <a href="/topics" class="d-s text-primary hover:text-accent transition-colors">
          &larr; All topics
        </a>
      </div>
    </div>
  </article>
</Layout>
